{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gts://gts.cf.llmgw.streaming.event.v1~x.llmgw.streaming.response_completed.v1~",
  "title": "Response completed event",
  "description": "A streaming event indicating the response was completed.",
  "allOf": [
    { "$ref": "gts://gts.cf.llmgw.streaming.event.v1~" },
    {
      "properties": {
        "type": {
          "type": "string",
          "const": "response.completed"
        },
        "response": {
          "$ref": "gts://gts.cf.llmgw.core.response_resource.v1~",
          "description": "The response snapshot that was emitted with the event."
        }
      },
      "required": ["type", "sequence_number", "response"]
    }
  ],
  "unevaluatedProperties": false
}
